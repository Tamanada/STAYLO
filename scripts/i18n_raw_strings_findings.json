          "line": 17,
          "text": "Privacy Policy",
          "raw": "<h1 className=\"text-3xl sm:text-4xl font-bold mb-2\">Privacy Policy</h1>"
        },
        {
          "line": 25,
          "text": "Account data",
          "raw": "<li><strong>Account data</strong>: email, full name, password hash (managed by Supabase Auth).</li>"
        },
        {
          "line": 26,
          "text": "Hotelier data",
          "raw": "<li><strong>Hotelier data</strong>: property details, photos, bank account info (held by Stripe Connect — STAYLO never sees full banking details).</li>"
        },
        {
          "line": 27,
          "text": "Booking data",
          "raw": "<li><strong>Booking data</strong>: dates, guest count, special requests, special-needs information you provide.</li>"
        },
        {
          "line": 28,
          "text": "Payment data",
          "raw": "<li><strong>Payment data</strong>: card details are processed by Stripe and never stored on our servers. Bitcoin Lightning invoices are stored as BOLT11 strings (no private keys).</li>"
        },
        {
          "line": 30,
          "text": "Usage data",
          "raw": "<li><strong>Usage data</strong>: anonymous analytics on which pages are visited (no cookies that track you across other sites).</li>"
        },
        {
          "line": 37,
          "text": "Process bookings and route payments to hoteliers",
          "raw": "<li>Process bookings and route payments to hoteliers</li>"
        },
        {
          "line": 38,
          "text": "Send booking confirmations and operational notifications",
          "raw": "<li>Send booking confirmations and operational notifications</li>"
        },
        {
          "line": 39,
          "text": "Calculate ambassador commissions and pay them in BTC to your declared Lightning address",
          "raw": "<li>Calculate ambassador commissions and pay them in BTC to your declared Lightning address</li>"
        },
        {
          "line": 40,
          "text": "Improve the Service (bug fixes, performance, new features)",
          "raw": "<li>Improve the Service (bug fixes, performance, new features)</li>"
        },
        {
          "line": 41,
          "text": "Comply with legal obligations (KYC/AML when triggered by share purchases or large payouts)",
          "raw": "<li>Comply with legal obligations (KYC/AML when triggered by share purchases or large payouts)</li>"
        },
        {
          "line": 49,
          "text": "Stripe Privacy Policy",
          "raw": "<li><strong>Stripe</strong> (payment processing) — see <a href=\"https://stripe.com/privacy\" target=\"_blank\" rel=\"noreferrer\" className=\"text-orange\">Stripe Privacy Policy</a>.</li>"
        },
        {
          "line": 50,
          "text": "Lightning provider",
          "raw": "<li><strong>Lightning provider</strong> (BTCPay Server self-hosted or similar) — for crypto payments.</li>"
        },
        {
          "line": 51,
          "text": "Supabase Privacy Policy",
          "raw": "<li><strong>Supabase</strong> (database + auth) — see <a href=\"https://supabase.com/privacy\" target=\"_blank\" rel=\"noreferrer\" className=\"text-orange\">Supabase Privacy Policy</a>.</li>"
        },
        {
          "line": 59,
          "text": "You have the right to:",
          "raw": "<p>You have the right to:</p>"
        },
        {
          "line": 61,
          "text": "Access the personal data we hold about you",
          "raw": "<li>Access the personal data we hold about you</li>"
        },
        {
          "line": 62,
          "text": "Request correction or deletion of your data",
          "raw": "<li>Request correction or deletion of your data</li>"
        },
        {
          "line": 63,
          "text": "Withdraw consent at any time (deleting your account removes most data; some bookings may be retained for legal/accounting reasons)",
          "raw": "<li>Withdraw consent at any time (deleting your account removes most data; some bookings may be retained for legal/accounting reasons)</li>"
