# ============================================
# STAYLO — Environment variables
# ============================================
# Copy this file to .env.local and fill in your real values.
# Never commit .env.local — it's gitignored.
# ============================================

# ── Supabase (browser-side, safe to expose) ─────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbG...your-anon-key...

# ============================================
# The variables below are NOT used by the browser.
# They live in Supabase Edge Functions Secrets.
# Set them at: https://supabase.com/dashboard/project/<id>/settings/functions
# ============================================

# ── Stripe (server-side only — Edge Functions) ──────────
# Get from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Get from: https://dashboard.stripe.com/test/webhooks (after creating the endpoint)
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Cron auth (for release-escrow scheduled job) ────────
# Generate any random string (≥32 chars). Used by the cron caller to
# authenticate against /functions/v1/release-escrow.
# Generate: `openssl rand -hex 32`
CRON_SECRET=replace-with-random-32-byte-hex

# ── Supabase service-role (auto-set by Supabase, no need to manually configure) ──
# SUPABASE_URL                  ← auto
# SUPABASE_ANON_KEY             ← auto
# SUPABASE_SERVICE_ROLE_KEY     ← auto
